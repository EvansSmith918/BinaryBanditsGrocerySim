<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BinaryBanditsGrocerySim.Models"
             x:Class="BinaryBanditsGrocerySim.ItemPage"
             Title="Items">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label x:Name="AisleLabel" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold" />
        <ListView x:Name="ItemListView" RowHeight="80">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <ViewCell>
                        <Grid Padding="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackLayout Grid.Column="0">
                                <Label Text="{Binding Name}" Style="{StaticResource LabelStyle}" />
                                <Label Text="{Binding Price, StringFormat='Price: {0:C}'}" FontSize="14" TextColor="Gray" />
                            </StackLayout>
                            <Button Text="Add to Cart" Grid.Column="1" Clicked="OnAddToCartClicked" CommandParameter="{Binding .}" Margin="5,0" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BinaryBanditsGrocerySim.CustomerServicePage"
             Title="Customer Service">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Customer Service" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold" />
        <Label Text="Contact us at support@binarybandits.com" Style="{StaticResource LabelStyle}" HorizontalOptions="Center" />
        <Button Text="Back to Home" Style="{StaticResource NavigationButtonStyle}" Clicked="OnBackToHomeClicked" />
    </VerticalStackLayout>
</ContentPage>
<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BinaryBanditsGrocerySim.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BinaryBanditsGrocerySim"
    Shell.BackgroundColor="#F5F5F5">

    <!-- TabBar for main navigation -->
    <TabBar>
        <!-- Home Tab -->
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:HomePage}" Route="HomePage" />
        </Tab>

        <!-- Cart Tab -->
        <Tab Title="Cart" Icon="cart.png">
            <ShellContent ContentTemplate="{DataTemplate local:CartPage}" Route="CartPage" />
        </Tab>

        <!-- Inventory Tab -->
        <Tab Title="Inventory" Icon="inventory.png">
            <ShellContent ContentTemplate="{DataTemplate local:InventoryManagerPage}" Route="InventoryManagerPage" />
        </Tab>

        <!-- Promotions Tab -->
        <Tab Title="Promotions" Icon="promotions.png">
            <ShellContent ContentTemplate="{DataTemplate local:PromotionsPage}" Route="PromotionsPage" />
        </Tab>

        <!-- Settings Tab -->
        <Tab Title="Settings" Icon="settings.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage" />
        </Tab>

        <!-- Customer Service Tab -->
        <Tab Title="Support" Icon="support.png">
            <ShellContent ContentTemplate="{DataTemplate local:CustomerServicePage}" Route="CustomerServicePage" />
        </Tab>
    </TabBar>

    <!-- Define routes for pages not in the TabBar (for hierarchical navigation) -->
    <ShellContent ContentTemplate="{DataTemplate local:AislePage}" Route="AislePage" />
    <ShellContent ContentTemplate="{DataTemplate local:ItemPage}" Route="ItemPage" />
    <ShellContent ContentTemplate="{DataTemplate local:CheckoutPage}" Route="CheckoutPage" />

</Shell>

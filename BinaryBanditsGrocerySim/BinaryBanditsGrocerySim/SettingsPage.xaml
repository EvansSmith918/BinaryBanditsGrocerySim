<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BinaryBanditsGrocerySim"
             x:Class="BinaryBanditsGrocerySim.SettingsPage"
             x:DataType="local:SettingsPage"
             Title="Settings">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Settings" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold" />
        <StackLayout Orientation="Horizontal" HorizontalOptions="Center">
            <Label Text="Dark Mode:" Style="{StaticResource LabelStyle}" VerticalOptions="Center" />
            <Switch x:Name="DarkModeSwitch" IsToggled="{Binding IsDarkMode}" Toggled="OnDarkModeToggled" VerticalOptions="Center" />
        </StackLayout>
        <Button Text="Back to Home" Style="{StaticResource NavigationButtonStyle}" Clicked="OnBackToHomeClicked" />
    </VerticalStackLayout>
</ContentPage>
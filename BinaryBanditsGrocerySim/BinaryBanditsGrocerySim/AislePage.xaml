<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BinaryBanditsGrocerySim.AislePage"
             Title="Browse Aisles">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Select an Aisle" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold" />
        <ListView x:Name="AisleListView" ItemTapped="OnAisleTapped" RowHeight="60">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <ViewCell>
                        <Label Text="{Binding .}" Style="{StaticResource LabelStyle}" Margin="10" />
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>